{
  "name": "Vibe",
  "scopeName": "source.vibe",
  "fileTypes": ["vibe"],
  "patterns": [
    { "include": "#comments" },
    { "include": "#strings" },
    { "include": "#numbers" },
    { "include": "#keywords" },
    { "include": "#types" },
    { "include": "#modules" },
    { "include": "#functions" },
    { "include": "#decorators" },
    { "include": "#operators" },
    { "include": "#variables" },
    { "include": "#regex" },
    { "include": "#interpolation" }
  ],
  "repository": {
    "comments": {
      "patterns": [
        {
          "name": "comment.line.double-slash.vibe",
          "match": "//.*$"
        },
        {
          "name": "comment.line.documentation.vibe",
          "match": "///.*$"
        },
        {
          "name": "comment.block.vibe",
          "begin": "/\\*",
          "end": "\\*/"
        }
      ]
    },
    "strings": {
      "patterns": [
        {
          "name": "string.quoted.triple.vibe",
          "begin": "\"\"\"",
          "end": "\"\"\"",
          "patterns": [
            {
              "name": "meta.embedded.expression.vibe",
              "begin": "\\{",
              "end": "\\}",
              "patterns": [{ "include": "source.vibe" }]
            }
          ]
        },
        {
          "name": "string.quoted.double.vibe",
          "begin": "\"",
          "end": "\"",
          "patterns": [
            {
              "name": "constant.character.escape.vibe",
              "match": "\\\\."
            },
            {
              "name": "meta.embedded.expression.vibe",
              "begin": "\\{",
              "end": "\\}",
              "patterns": [{ "include": "source.vibe" }]
            }
          ]
        },
        {
          "name": "string.quoted.single.vibe",
          "begin": "'",
          "end": "'",
          "patterns": [
            { "name": "constant.character.escape.vibe", "match": "\\\\." }
          ]
        }
      ]
    },
    "numbers": {
      "patterns": [
        {
          "name": "constant.numeric.hex.vibe",
          "match": "\\b0[xX][0-9a-fA-F_]+\\b"
        },
        {
          "name": "constant.numeric.binary.vibe",
          "match": "\\b0[bB][01_]+\\b"
        },
        {
          "name": "constant.numeric.octal.vibe",
          "match": "\\b0[oO][0-7_]+\\b"
        },
        {
          "name": "constant.numeric.float.vibe",
          "match": "\\b[0-9][0-9_]*\\.[0-9][0-9_]*([eE][+-]?[0-9_]+)?\\b"
        },
        {
          "name": "constant.numeric.integer.vibe",
          "match": "\\b[0-9][0-9_]*\\b"
        }
      ]
    },
    "keywords": {
      "patterns": [
        {
          "name": "keyword.control.vibe",
          "match": "\\b(if|else|for|while|loop|match|case|return|break|continue|yield|defer|guard|try|catch|finally|throw|in|step|async|await)\\b"
        },
        {
          "name": "keyword.declaration.vibe",
          "match": "\\b(let|const|fn|class|interface|enum|type|import|export|from|extends|implements|operator|macro|module)\\b"
        },
        {
          "name": "keyword.modifier.vibe",
          "match": "\\b(static|private|public|protected|abstract|override|mut|ref|move)\\b"
        },
        {
          "name": "constant.language.vibe",
          "match": "\\b(true|false|null|undefined|this|self|super)\\b"
        },
        {
          "name": "keyword.operator.logical.vibe",
          "match": "\\b(and|or|not|is|as)\\b"
        },
        {
          "name": "keyword.other.vibe",
          "match": "\\b(new|show|where|with)\\b"
        }
      ]
    },
    "types": {
      "patterns": [
        {
          "name": "support.type.primitive.vibe",
          "match": "\\b(Int|Float|String|Bool|Array|Map|Set|Tuple|Result|Option|Any|Void|Never|Char|Byte)\\b"
        },
        {
          "name": "entity.name.type.class.vibe",
          "match": "\\b[A-Z][a-zA-Z0-9]*\\b"
        }
      ]
    },
    "modules": {
      "patterns": [
        {
          "name": "support.module.vibe",
          "match": "\\b(dsa|neural|ai|data|viz|image|web|db|crypto|fs|async|test|math|audio|cloud|game|web3|iot|robot|quantum)\\b"
        }
      ]
    },
    "functions": {
      "patterns": [
        {
          "name": "entity.name.function.vibe",
          "match": "\\b([a-zA-Z_][a-zA-Z0-9_]*)\\s*(?=\\()"
        },
        {
          "name": "support.function.builtin.vibe",
          "match": "\\b(show|input|typeof|sizeof|assert|panic|todo|unreachable|print|println|format|range|enumerate|zip|len|map|filter|reduce|forEach|find|some|every|flat|flatMap|sort|reverse|join|split|trim|replace|contains|startsWith|endsWith|toInt|toFloat|toString|toBool|toArray|toMap|toSet|append|prepend|insert|remove|pop|push|shift|unshift|slice|splice|concat|includes|indexOf|lastIndexOf|fill|keys|values|entries|freeze|clone|deepClone|merge|isEmpty|isNull|isUndefined|isNumber|isString|isBool|isArray|isMap|isFunction|Tensor|Dense|Dropout|Conv2D|MaxPool2D|Flatten|Sequential|SGD|Adam|MSELoss|CrossEntropyLoss|ReLU|Sigmoid|Tanh|train|quickSort|bubbleSort|binarySearch|linearSearch|bfs|dfs|dijkstra|Graph|MinHeap|MaxHeap|trainTestSplit|accuracy|precision|recall|f1Score|confusionMatrix|DataFrame|readCSV|writeCSV|head|describe|groupBy|loadImage|saveImage|resizeImage|cropImage|rotateImage|flipImage|adjustBrightness|applyBlur|detectEdges)\\b"
        }
      ]
    },
    "decorators": {
      "patterns": [
        {
          "name": "meta.decorator.vibe",
          "match": "@[a-zA-Z_][a-zA-Z0-9_]*",
          "captures": {
            "0": { "name": "entity.name.decorator.vibe" }
          }
        }
      ]
    },
    "operators": {
      "patterns": [
        {
          "name": "keyword.operator.pipe.vibe",
          "match": "\\|>"
        },
        {
          "name": "keyword.operator.arrow.vibe",
          "match": "(=>|->)"
        },
        {
          "name": "keyword.operator.spread.vibe",
          "match": "\\.\\.\\."
        },
        {
          "name": "keyword.operator.range.vibe",
          "match": "\\.\\."
        },
        {
          "name": "keyword.operator.null-coalescing.vibe",
          "match": "\\?\\?"
        },
        {
          "name": "keyword.operator.optional-chain.vibe",
          "match": "\\?\\."
        },
        {
          "name": "keyword.operator.comparison.vibe",
          "match": "(==|!=|<=|>=|<|>)"
        },
        {
          "name": "keyword.operator.assignment.vibe",
          "match": "(\\+=|-=|\\*=|/=|%=|\\*\\*=|=)"
        },
        {
          "name": "keyword.operator.arithmetic.vibe",
          "match": "(\\+|-|\\*\\*|\\*|/|%)"
        },
        {
          "name": "keyword.operator.logical.symbol.vibe",
          "match": "(&&|\\|\\||!)"
        }
      ]
    },
    "regex": {
      "patterns": [
        {
          "name": "string.regexp.vibe",
          "begin": "(?<=[=(:,\\[!&|?{;]|^)\\s*/(?![/*])",
          "end": "/[gimsuxy]*",
          "patterns": [
            {
              "name": "constant.character.escape.regexp.vibe",
              "match": "\\\\."
            }
          ]
        }
      ]
    },
    "interpolation": {
      "patterns": [
        {
          "name": "meta.interpolation.vibe",
          "begin": "\\{",
          "end": "\\}",
          "patterns": [{ "include": "source.vibe" }]
        }
      ]
    },
    "variables": {
      "patterns": [
        {
          "name": "variable.other.vibe",
          "match": "\\b[a-z_][a-zA-Z0-9_]*\\b"
        }
      ]
    }
  }
}
