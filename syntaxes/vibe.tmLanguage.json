{
  "scopeName": "source.vibe",
  "patterns": [
    { "include": "#comments" },
    { "include": "#strings" },
    { "include": "#numbers" },
    { "include": "#constants" },
    { "include": "#keywords-control" },
    { "include": "#keywords-declaration" },
    { "include": "#keywords-modifier" },
    { "include": "#keywords-operator" },
    { "include": "#types" },
    { "include": "#class-definition" },
    { "include": "#function-definition" },
    { "include": "#function-call" },
    { "include": "#operators" },
    { "include": "#punctuation" },
    { "include": "#variables" }
  ],
  "repository": {
    "comments": {
      "patterns": [
        {
          "name": "comment.line.double-slash.vibe",
          "match": "//.*$"
        },
        {
          "name": "comment.block.vibe",
          "begin": "/\\*",
          "end": "\\*/"
        }
      ]
    },
    "strings": {
      "patterns": [
        {
          "name": "string.quoted.double.vibe",
          "begin": "\"",
          "end": "\"",
          "patterns": [
            {
              "name": "constant.character.escape.vibe",
              "match": "\\\\[nrtf0\\\\\"']"
            },
            {
              "name": "variable.other.interpolation.vibe",
              "match": "\\{[^}]+\\}"
            }
          ]
        },
        {
          "name": "string.quoted.single.vibe",
          "begin": "'",
          "end": "'",
          "patterns": [
            {
              "name": "constant.character.escape.vibe",
              "match": "\\\\[nrtf0\\\\\"']"
            }
          ]
        }
      ]
    },
    "numbers": {
      "patterns": [
        {
          "name": "constant.numeric.float.scientific.vibe",
          "match": "\\b\\d+\\.\\d+[eE][+-]?\\d+\\b"
        },
        {
          "name": "constant.numeric.integer.scientific.vibe",
          "match": "\\b\\d+[eE][+-]?\\d+\\b"
        },
        {
          "name": "constant.numeric.float.vibe",
          "match": "\\b\\d+\\.\\d+\\b"
        },
        {
          "name": "constant.numeric.hex.vibe",
          "match": "\\b0[xX][0-9a-fA-F]+\\b"
        },
        {
          "name": "constant.numeric.binary.vibe",
          "match": "\\b0[bB][01]+\\b"
        },
        {
          "name": "constant.numeric.integer.vibe",
          "match": "\\b\\d+\\b"
        }
      ]
    },
    "constants": {
      "patterns": [
        {
          "name": "constant.language.boolean.vibe",
          "match": "\\b(true|false)\\b"
        },
        {
          "name": "constant.language.null.vibe",
          "match": "\\b(null)\\b"
        },
        {
          "name": "variable.language.self.vibe",
          "match": "\\b(self|super)\\b"
        }
      ]
    },
    "keywords-control": {
      "patterns": [
        {
          "name": "keyword.control.flow.vibe",
          "match": "\\b(if|else|for|in|while|do|match|return|break|continue|throw|try|catch|finally|spawn|await|yield)\\b"
        },
        {
          "name": "keyword.control.import.vibe",
          "match": "\\b(import|export|from|as)\\b"
        }
      ]
    },
    "keywords-declaration": {
      "patterns": [
        {
          "name": "keyword.declaration.vibe",
          "match": "\\b(var|let|const|fn|class|interface|enum|type|init|new)\\b"
        }
      ]
    },
    "keywords-modifier": {
      "patterns": [
        {
          "name": "keyword.modifier.vibe",
          "match": "\\b(async|static|override|private|public|protected|extends|implements|unsafe|get|set)\\b"
        }
      ]
    },
    "keywords-operator": {
      "patterns": [
        {
          "name": "keyword.operator.logical.vibe",
          "match": "\\b(and|or|not|is)\\b"
        }
      ]
    },
    "types": {
      "patterns": [
        {
          "name": "support.type.primitive.vibe",
          "match": "\\b(int|int8|int16|int32|int64|float|float32|float64|bool|char|str|string|byte|void|any|auto)\\b"
        }
      ]
    },
    "class-definition": {
      "patterns": [
        {
          "match": "\\b(class)\\s+([A-Z][A-Za-z0-9_]*)(?:\\s+(extends)\\s+([A-Z][A-Za-z0-9_]*))?",
          "captures": {
            "1": { "name": "keyword.declaration.class.vibe" },
            "2": { "name": "entity.name.type.class.vibe" },
            "3": { "name": "keyword.modifier.extends.vibe" },
            "4": { "name": "entity.other.inherited-class.vibe" }
          }
        },
        {
          "match": "\\b(interface)\\s+([A-Z][A-Za-z0-9_]*)",
          "captures": {
            "1": { "name": "keyword.declaration.interface.vibe" },
            "2": { "name": "entity.name.type.interface.vibe" }
          }
        },
        {
          "match": "\\b(enum)\\s+([A-Z][A-Za-z0-9_]*)",
          "captures": {
            "1": { "name": "keyword.declaration.enum.vibe" },
            "2": { "name": "entity.name.type.enum.vibe" }
          }
        }
      ]
    },
    "function-definition": {
      "patterns": [
        {
          "match": "\\b(fn)\\s+([a-zA-Z_][a-zA-Z0-9_]*)\\s*(?=\\()",
          "captures": {
            "1": { "name": "keyword.declaration.function.vibe" },
            "2": { "name": "entity.name.function.vibe" }
          }
        }
      ]
    },
    "function-call": {
      "patterns": [
        {
          "match": "\\b(print|println|input|write|range|len|type|typeof|str|int|float|bool|abs|min|max|sum|sorted|reversed|flatten|unique|zip|enumerate|keys|values|join|reduce|map|filter|chr|ord|format|assert|clock|timestamp|random|hash|toJSON|list|repeat|isNull|isInt|isFloat|isStr|isBool|isList|isMap|isFunction|exit|push)\\s*(?=\\()",
          "captures": {
            "1": { "name": "support.function.builtin.vibe" }
          }
        },
        {
          "match": "\\b([a-zA-Z_][a-zA-Z0-9_]*)\\s*(?=\\()",
          "captures": {
            "1": { "name": "entity.name.function.call.vibe" }
          }
        }
      ]
    },
    "operators": {
      "patterns": [
        {
          "name": "keyword.operator.assignment.vibe",
          "match": "(\\+=|-=|\\*=|/=|%=|=)"
        },
        {
          "name": "keyword.operator.comparison.vibe",
          "match": "(==|!=|<=|>=|<|>)"
        },
        {
          "name": "keyword.operator.arithmetic.vibe",
          "match": "(\\*\\*|~/|\\+|-|\\*|/|%)"
        },
        {
          "name": "keyword.operator.logical.vibe",
          "match": "(&&|\\|\\||!)"
        },
        {
          "name": "keyword.operator.bitwise.vibe",
          "match": "(<<|>>|&|\\||\\^|~)"
        },
        {
          "name": "keyword.operator.arrow.vibe",
          "match": "(=>|->)"
        },
        {
          "name": "keyword.operator.range.vibe",
          "match": "\\.\\."
        },
        {
          "name": "keyword.operator.spread.vibe",
          "match": "\\.\\.\\."
        }
      ]
    },
    "punctuation": {
      "patterns": [
        {
          "name": "punctuation.separator.comma.vibe",
          "match": ","
        },
        {
          "name": "punctuation.terminator.semicolon.vibe",
          "match": ";"
        },
        {
          "name": "punctuation.accessor.dot.vibe",
          "match": "\\."
        }
      ]
    },
    "variables": {
      "patterns": [
        {
          "name": "variable.other.constant.vibe",
          "match": "\\b[A-Z][A-Z0-9_]+\\b"
        },
        {
          "name": "entity.name.type.vibe",
          "match": "\\b[A-Z][A-Za-z0-9_]*\\b"
        }
      ]
    }
  }
}

